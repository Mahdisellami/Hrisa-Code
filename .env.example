# Hrisa Code Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=false

# =============================================================================
# Ollama Configuration
# =============================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=300

# For Docker deployments:
# OLLAMA_HOST=http://ollama:11434

# =============================================================================
# Agent Configuration
# =============================================================================
MAX_CONCURRENT_AGENTS=5
STUCK_THRESHOLD_SECONDS=120

# =============================================================================
# Web UI Configuration
# =============================================================================
ENABLE_WEB_UI=true
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8000

# =============================================================================
# Database Configuration (Required for authentication)
# =============================================================================
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://hrisa:hrisa_password@localhost:5432/hrisa

# For Docker deployments, use the service name:
# DATABASE_URL=postgresql://hrisa:hrisa_password@postgres:5432/hrisa

# Enable SQL query logging (useful for debugging)
DB_ECHO=false

# =============================================================================
# SMTP Email Configuration (Required for magic link authentication)
# =============================================================================

# SMTP Server Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# From Email Address
SMTP_FROM_EMAIL=noreply@hrisa.local

# Gmail Setup Instructions:
# 1. Enable 2FA on your Gmail account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated app password as SMTP_PASSWORD

# Other Popular SMTP Providers:
# - SendGrid: smtp.sendgrid.net (port 587)
# - Mailgun: smtp.mailgun.org (port 587)
# - AWS SES: email-smtp.us-east-1.amazonaws.com (port 587)
# - Outlook: smtp-mail.outlook.com (port 587)

# =============================================================================
# Authentication & Security Configuration
# =============================================================================

# Application Base URL (used for magic link generation)
APP_BASE_URL=http://localhost:8000

# Secret Key for session encryption (generate with: openssl rand -hex 32)
SECRET_KEY=change-this-to-a-random-32-byte-hex-string-in-production

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Session Expiry (days)
SESSION_EXPIRY_DAYS=30

# Magic Link Token Expiry (minutes)
MAGIC_LINK_EXPIRY_MINUTES=15

# =============================================================================
# Integration Configuration
# =============================================================================
WEBHOOK_TIMEOUT_SECONDS=10
MAX_WEBHOOK_RETRIES=0
ENABLE_WEBHOOK_SIGNATURES=true

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=hrisa.log

# =============================================================================
# Redis (optional - for future caching)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Monitoring (optional)
# =============================================================================
SENTRY_DSN=
ENABLE_METRICS=false

# =============================================================================
# Development/Testing
# =============================================================================
DEBUG=false
TESTING=false

# =============================================================================
# Production Deployment Checklist
# =============================================================================
#
# Before deploying to production:
#
# 1. DATABASE_URL: Use a managed PostgreSQL instance (RDS, Cloud SQL, etc.)
#    with strong password and SSL enabled
#
# 2. SECRET_KEY: Generate a new random secret:
#    openssl rand -hex 32
#
# 3. SMTP: Use a production email service (SendGrid, Mailgun, AWS SES)
#    with appropriate sending limits and monitoring
#
# 4. APP_BASE_URL: Set to your actual domain (https://your-domain.com)
#
# 5. ALLOWED_ORIGINS: Restrict to your actual frontend domains only
#
# 6. DB_ECHO: Set to 'false' to reduce log verbosity
#
# 7. Environment: Never commit .env file to version control!
#    Add .env to .gitignore
#
# 8. Database Backups: Enable automated backups for PostgreSQL
#
# 9. Monitoring: Set up logging and monitoring for auth events
#
# 10. SSL/TLS: Ensure HTTPS is enforced in production
#
# =============================================================================
